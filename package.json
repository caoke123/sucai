{
  "name": "material-sorter",
  "version": "4.6.0",
  "description": "产品素材分拣工具",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "agent": "npx tsx --tsconfig agent/tsconfig.json agent/server.ts",
    "dist": "electron-vite build && electron-builder --win zip",
    "dist:mac": "electron-vite build && electron-builder --mac dmg",
    "dist:linux": "electron-vite build && electron-builder --linux AppImage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "axios": "^1.16.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "express": "^4.21.0",
    "immer": "^10.1.0",
    "pg": "^8.21.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.33.0",
    "tslib": "^2.8.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.material-sorter",
    "productName": "雨图饰品素材分拣系统",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": "zip",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
